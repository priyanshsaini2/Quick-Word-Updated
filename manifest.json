{
  "manifest_version": 3,
  "name": "QuickWord – Instant Dictionary",
  "short_name": "QuickWord",
  "version": "1.0.0",
  "description": "Select any 1–2 words on a webpage and instantly get definitions, synonyms, examples, and pronunciation. Saves your words for later review.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "QuickWord – My Words"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/local-dictionary.js",
        "lib/storage.js",
        "lib/dictionary.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "*://api.dictionaryapi.dev/*"
  ],
  "web_accessible_resources": []
}
